# =============================================================================
# ScanRay Sonar - Example environment file
# Copy to .env and fill in real values. Never commit a real .env.
# Or run: bash scripts/dev-bootstrap.sh  (generates secrets; still set URLs)
# Full install guide: docs/src/installation.md
# =============================================================================

# --- Application -------------------------------------------------------------
SONAR_ENV=production                          # production | development
SONAR_LOG_LEVEL=info                          # debug | info | warn | error
SONAR_BIND_ADDR=0.0.0.0:8080                  # API/UI bind inside the container
SONAR_API_PORT=6969                           # Host-side port published by docker
SONAR_API_BIND=0.0.0.0                        # Host interface (0.0.0.0=LAN-reachable, 127.0.0.1=cloudflared-only)
SONAR_PUBLIC_URL=https://sonar.example.com    # External URL (Cloudflare Tunnel hostname)
SONAR_INGEST_URL=https://ingest.example.com   # Public agent ingest URL

# --- Master encryption key (REQUIRED) ----------------------------------------
# 32 bytes (256 bits) base64-encoded. Generate with:
#   openssl rand -base64 32
# This key wraps every secret in the database. Losing it loses every secret.
SONAR_MASTER_KEY=

# --- JWT signing secret (REQUIRED) -------------------------------------------
# 64 random bytes base64-encoded.
#   openssl rand -base64 64
SONAR_JWT_SECRET=
SONAR_JWT_ACCESS_TTL=15m
SONAR_JWT_REFRESH_TTL=720h                    # 30 days

# --- Postgres ----------------------------------------------------------------
SONAR_DB_HOST=sonar-postgres
SONAR_DB_PORT=5432
SONAR_DB_NAME=sonar
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=changeme
SONAR_DB_SSLMODE=disable
SONAR_DB_MAX_OPEN=25
SONAR_DB_MAX_IDLE=5

# --- NATS --------------------------------------------------------------------
SONAR_NATS_URL=nats://sonar-nats:4222

# --- MinIO (optional; site Documents object offload) -------------------------
# Compose starts sonar-minio. When set, the API stores document bodies in MinIO
# instead of falling back to Postgres enc_body. Defaults match docker-compose.yml.
# SONAR_MINIO_ENDPOINT=sonar-minio:9000
# SONAR_MINIO_USER=minio
# SONAR_MINIO_PASSWORD=changeme_minio_root
# SONAR_MINIO_BUCKET=sonar-documents
# SONAR_MINIO_SSL=false

# --- Collector install image (optional) --------------------------------------
# Surfaced in the Collectors UI install commands. Default when unset:
#   glcr.nclgisa.org:443/striketeam/scanray-sonar/collector:latest
# SONAR_COLLECTOR_IMAGE=

# --- SMTP (optional, for email alerts) ---------------------------------------
SONAR_SMTP_HOST=
SONAR_SMTP_PORT=587
SONAR_SMTP_USER=
SONAR_SMTP_PASSWORD=
SONAR_SMTP_FROM=sonar@example.com
SONAR_SMTP_TLS=true

# --- Bootstrap admin (only used on first run if no users exist) --------------
SONAR_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SONAR_BOOTSTRAP_ADMIN_PASSWORD=

# --- MaxMind GeoLite2 (optional, for the World map + ASN labels) -------------
# Account ID + license key from your MaxMind GeoIP2 account; used by
# scripts/refresh-geoip.sh to download GeoLite2-City and GeoLite2-ASN
# into the sonar-geoip docker volume. The API container reads them
# from /var/lib/sonar/geoip at startup; without these the world map
# still works but pins agents at "unknown".
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
SONAR_GEOIP_CITY_DB=/var/lib/sonar/geoip/GeoLite2-City.mmdb
SONAR_GEOIP_ASN_DB=/var/lib/sonar/geoip/GeoLite2-ASN.mmdb

# --- Poller optional listeners (optional) ------------------------------------
# SONAR_SNMP_TRAP_LISTEN=:162
# SONAR_FLOW_LISTEN=:2055
# SONAR_MERAKI_API_KEY=          # env fallback; prefer sealed key in site discovery UI
# SONAR_MERAKI_SITE_ID=

# --- OIDC (stubs; optional) --------------------------------------------------
# SONAR_OIDC_ISSUER=
# SONAR_OIDC_CLIENT_ID=
# SONAR_OIDC_CLIENT_SECRET=
# SONAR_OIDC_REDIRECT=

# --- Registry pull-only deploy (docker-compose.registry.yml) ---------------
# IMAGE_TAG applies to sonar-api, sonar-poller, and (with the dev-collector
# overlay) sonar-collector — keep them identical.
# deploy-registry.sh defaults IMAGE_TAG to latest unless already exported.
# Pin a CalVer/SHA for rollback: IMAGE_TAG=2026.7.16.1
# SCANRAY_STACK_VERSION is stamped as Docker label com.scanraysonar.release.
# IMAGE_TAG=latest
# SCANRAY_STACK_VERSION=
