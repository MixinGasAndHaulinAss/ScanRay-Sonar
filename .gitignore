.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/
master.key

# Local data (only used outside containers)
data/
*.db
*.sqlite

# Generated code (regenerated by `make generate` once Phase 2 wires sqlc + oapi-codegen)
internal/api/openapi_gen.go
internal/db/sqlc/queries.sql.go
internal/db/sqlc/models.go
