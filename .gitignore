# Build artifacts
/bin/
/dist/
/build/
*.exe
*.test
*.out
*.prof
coverage.*

# Go
/vendor/

# Web — see web/.gitignore for the dist exception (we track the placeholder)
node_modules/
.pnpm-debug.log*
.npm/

# IDE / editor
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

