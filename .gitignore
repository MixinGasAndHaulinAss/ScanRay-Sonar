# Build artifacts
/bin/
/dist/
/build/
/unsigned/
pre-signed/*
!pre-signed/.gitkeep
*.exe
*.test
*.out
*.prof
coverage.*

# Go
/vendor/

# Web — see web/.gitignore for the dist exception (we track the placeholder)
node_modules/
.pnpm-debug.log*
.npm/

# MkDocs build output — keep placeholder docs/site/index.html for go:embed
docs/site/**
!docs/site/index.html

# IDE / editor
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# Local scratch — temp files used by tooling (e.g. multi-line git
# commit messages staged from the agent).
.git-commit-msg.tmp

# Local SNMP OID extract (reference only). Transform into
# internal/snmp/oidpack/data via scripts/build-oidpacks.py — do not commit.
/oid_bundle/

# Local full-sensor product catalog (reference only). Transform into
# internal/checks/catalog via scripts/build-checkpacks.py — do not commit.
/prtg_full_sensor_catalog/

# Environment / secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
# Track the placeholder for the optional corporate CA bundle so the
# Dockerfiles always have something to COPY. Operators on hosts behind
# TLS-inspecting proxies populate it locally via
# `scripts/inject-host-ca.sh`, which also marks the path
# --skip-worktree so the populated content cannot be accidentally
# committed.
!docker/local-ca.crt
secrets/
master.key

# Local data (only used outside containers)
data/
# Embedded SNMP OID packs (generated offline; required by go:embed)
!internal/snmp/oidpack/data/
!internal/snmp/oidpack/data/**
*.db
*.sqlite

# Generated code (regenerated by `make generate` once Phase 2 wires sqlc + oapi-codegen)
internal/api/openapi_gen.go
internal/db/sqlc/queries.sql.go
internal/db/sqlc/models.go
